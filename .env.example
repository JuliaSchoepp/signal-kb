# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Signal
SIGNAL_WS_URL=ws://localhost:8080/v1/receive/+49...  # full URL incl. bot number
SIGNAL_ACCOUNT=+49...          # bot phone number in E.164 format
SIGNAL_GROUP_ID=...            # base64 group ID (retrieve from first received message log)

# Vault
VAULT_PATH=/mnt/ssd/verwaltungsdigitalisierung-kb
VAULT_TAGS_FILE=               # optional override; defaults to {VAULT_PATH}/tags.yaml
GITHUB_REMOTE=origin
